{
  "version": 2,
  "functions": {
    "apps/dashboard/server.js": {
      "includeFiles": "tools/**"
    }
  },
  "builds": [
    {
      "src": "apps/dashboard/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/apps/dashboard/server.js"
    }
  ]
}
