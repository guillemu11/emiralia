{
  "version": 2,
  "builds": [
    {
      "src": "apps/dashboard/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "apps/dashboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "apps/dashboard/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/apps/dashboard/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/apps/dashboard/dist/$1"
    }
  ]
}
