# ─── Apify ───────────────────────────────────────────────────────────────────
APIFY_TOKEN=tu_token_aqui

# ─── PostgreSQL (debe coincidir con docker-compose.yml) ───────────────────────
PG_HOST=localhost
PG_PORT=5433
PG_DB=emiralia
PG_USER=emiralia
PG_PASSWORD=changeme

# ─── Scraper config ───────────────────────────────────────────────────────────
# URL de búsqueda de PropertyFinder (off-plan, Dubai, venta)
# Para construirla: filtra en propertyfinder.ae y copia la URL resultante
# c=1 → for sale | fu=0 → off-plan | ob=nd → newest first
SEARCH_URL=https://www.propertyfinder.ae/en/search?c=1&fu=0&rms=1&ob=nd

# Número máximo de propiedades a extraer (50 para test, 0 para sin límite)
MAX_RESULTS=50

# Threads paralelos de Apify (1-5 recomendado, más = más rápido pero más costoso)
APIFY_THREADS=3

# ─── PM Agent — Telegram ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=tu_token_aqui
# Obtener en: https://t.me/BotFather → /newbot

# ─── PM Agent — OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=tu_api_key_aqui
# Usado para: razonamiento GPT-4o + transcripción de voz Whisper

# ─── PM Agent — Notion ───────────────────────────────────────────────────────
NOTION_API_KEY=tu_integration_token_aqui
# Obtener en: https://www.notion.so/my-integrations → New integration

NOTION_DATABASE_ID=tu_database_id_aqui
# El ID está en la URL de tu DB de Notion:
# https://notion.so/workspace/[ESTE-ES-EL-ID]?v=...
# También en: Share → Copy link → el ID largo antes del "?"
